<Window
    x:Class="ImageExplorer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Image Explorer" Width="1280" Height="820">
    <Grid RowDefinitions="Auto,Auto,*" Padding="12" RowSpacing="10">
        <MenuBar>
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Open File" Click="OpenFile_Click"/>
                <MenuFlyoutItem Text="Open Folder" Click="OpenFolderMenu_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutSubItem Text="View">
                    <MenuFlyoutItem Text="Small Thumbnails" Click="ThumbSizeSmall_Click"/>
                    <MenuFlyoutItem Text="Medium Thumbnails" Click="ThumbSizeMedium_Click"/>
                    <MenuFlyoutItem Text="Large Thumbnails" Click="ThumbSizeLarge_Click"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSubItem Text="AI Detection">
                    <MenuFlyoutItem Text="Detect People (OpenCV HOG)" Click="DetectPeople_Click"/>
                    <MenuFlyoutItem Text="Detect Vehicles (DNN/YOLO)" Click="DetectVehicles_Click"/>
                    <MenuFlyoutItem Text="Detect Animals (DNN/YOLO)" Click="DetectAnimals_Click"/>
                    <MenuFlyoutItem Text="Detect Body Parts (Pose Heuristics)" Click="DetectBodyParts_Click"/>
                    <MenuFlyoutItem Text="Detect Text Regions (EAST/DB)" Click="DetectTextRegions_Click"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Preferences" Click="Preferences_Click"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Exit" Click="Exit_Click"/>
            </MenuBarItem>
            <MenuBarItem Title="Analyze">
                <MenuFlyoutItem Text="Find Faces and Objects" Click="AnalyzeImage_Click"/>
            </MenuBarItem>
        </MenuBar>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Open Folder" Click="OpenFolder_Click"/>
            <TextBlock Text="Thumbnail size" VerticalAlignment="Center"/>
            <Slider x:Name="ThumbSizeSlider" Width="220" Minimum="64" Maximum="280" Value="128" ValueChanged="ThumbSizeSlider_ValueChanged"/>
            <TextBlock x:Name="FolderNameText" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="2" ColumnDefinitions="2*,3*,2*" ColumnSpacing="12">
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="6">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Gallery (Dockable Pane)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1">
                        <GridView x:Name="ImageGrid" IsItemClickEnabled="True" ItemClick="ImageGrid_ItemClick">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate><ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7"/></ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                        </GridView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="8">
                <Grid>
                    <ScrollViewer x:Name="ImageScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PointerWheelChanged="ImageScrollViewer_PointerWheelChanged"
                                  PointerPressed="ImageScrollViewer_PointerPressed"
                                  PointerMoved="ImageScrollViewer_PointerMoved"
                                  PointerReleased="ImageScrollViewer_PointerReleased">
                        <Grid>
                            <Image x:Name="PreviewImage" Stretch="Uniform"/>
                            <Canvas x:Name="OverlayCanvas" Background="Transparent"
                                    RightTapped="OverlayCanvas_RightTapped"
                                    PointerPressed="OverlayCanvas_PointerPressed"
                                    PointerMoved="OverlayCanvas_PointerMoved"
                                    PointerReleased="OverlayCanvas_PointerReleased"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="6">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Metadata (Dockable Pane)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TabView Grid.Row="1">
                        <TabViewItem Header="General">
                            <StackPanel Spacing="6" Padding="8">
                                <TextBlock Text="File name" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FileNameValue" Text="-" TextWrapping="WrapWholeWords"/>
                                <TextBlock Text="Path" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FilePathValue" Text="-" TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </TabViewItem>
                        <TabViewItem Header="Properties">
                            <StackPanel Spacing="6" Padding="8">
                                <TextBlock Text="Type" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FileTypeValue" Text="-"/>
                                <TextBlock Text="Size" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FileSizeValue" Text="-"/>
                                <TextBlock Text="Modified" FontWeight="SemiBold"/>
                                <TextBlock x:Name="FileModifiedValue" Text="-"/>
                            </StackPanel>
                        </TabViewItem>
                    </TabView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
